<% content_for :title, "Resultado del pago" %>

<div class="panel-page">
  <section class="card block">
    <h1 class="block-title">Resultado del pago</h1>

    <% if @session.blank? %>
      <p class="block-text">No encontramos información de este pago. Si acabas de pagar, espera unos segundos mientras confirmamos la transacción.</p>
    <% else %>
      <dl class="profile-list">
        <div class="profile-row profile-row--full">
          <dt>Referencia</dt>
          <dd><%= @session[:reference] %></dd>
        </div>
        <div class="profile-row">
          <dt>Monto</dt>
          <dd><%= number_to_currency(@session[:amount], unit: "$", precision: 2) %></dd>
        </div>
        <div class="profile-row">
          <dt>Estado</dt>
          <dd>
            <% case @session[:status] %>
            <% when "authorized" %>
              Pago autorizado
            <% when "rejected" %>
              Pago rechazado
            <% when "reversed" %>
              Pago reversado
            <% else %>
              Pendiente de confirmación
            <% end %>
          </dd>
        </div>
        <% if @session[:cuotas].present? %>
          <div class="profile-row profile-row--full">
            <dt>Cuotas</dt>
            <dd><%= Array(@session[:cuotas]).join(", ") %></dd>
          </div>
        <% end %>
      </dl>

      <% if @session[:status] == "pending" %>
        <p class="block-text">Pagomedios está procesando tu pago. Recibirás la confirmación en breve.</p>
      <% elsif @session[:status] == "authorized" %>
        <p class="block-text">Tu pago fue aprobado. Pronto se reflejará en tu cuenta CLEV.</p>
        <% if @session[:q10_reported] %>
          <p class="block-text">El abono ya fue registrado en Q10.</p>
        <% elsif @session[:consecutivo_credito].present? %>
          <p class="block-text">Estamos registrando el abono en Q10. Si no se refleja en unos minutos, contacta a soporte.</p>
        <% end %>
      <% else %>
        <p class="block-text">El pago no se completó. Puedes intentarlo de nuevo desde tu panel.</p>
      <% end %>

      <% if @session[:return_token].present? %>
        <p class="panel-payment-actions">
          <%= link_to "Volver a mi panel", q10_continue_path(token: @session[:return_token]), class: "btn btn-primary" %>
        </p>
      <% end %>
    <% end %>
  </section>

  <footer class="panel-footer">© CLEV · Sistema Administrativo de Estudiantes</footer>
</div>
