<% content_for :title, "Pago completado" %>
<% content_for :head do %>
  <meta http-equiv="refresh" content="4;url=<%= ERB::Util.html_escape(@panel_url) %>">
  <script>
    (function () {
      var panelUrl = <%= @panel_url.to_json %>;
      var delayMs = 3500;

      function goToPanel() {
        if (window.top !== window.self) {
          window.top.location.replace(panelUrl);
        } else {
          window.location.replace(panelUrl);
        }
      }

      window.setTimeout(goToPanel, delayMs);
    })();
  </script>
<% end %>

<div class="panel-page payment-complete-page">
  <section class="card block payment-complete-card">
    <% if @session[:status] == "authorized" %>
      <div class="payment-complete-icon payment-complete-icon--success" aria-hidden="true">✓</div>
      <h1 class="block-title payment-complete-title">Pago ejecutado correctamente</h1>
      <p class="block-text payment-complete-lead">
        Tu transacción fue aprobada por Pagomedios.
        <% if @session[:q10_reported] %>
          El abono ya fue registrado en Q10.
        <% else %>
          Estamos registrando el abono en Q10.
        <% end %>
      </p>
    <% elsif @session[:status].in?(%w[rejected reversed]) %>
      <div class="payment-complete-icon payment-complete-icon--error" aria-hidden="true">!</div>
      <h1 class="block-title payment-complete-title">Pago no completado</h1>
      <p class="block-text payment-complete-lead">
        La transacción no fue aprobada. En unos segundos volverás a tu panel para intentarlo de nuevo.
      </p>
    <% else %>
      <div class="payment-complete-icon payment-complete-icon--pending" aria-hidden="true">…</div>
      <h1 class="block-title payment-complete-title">Pago en proceso</h1>
      <p class="block-text payment-complete-lead">
        Estamos confirmando tu pago. En unos segundos volverás a tu panel.
      </p>
    <% end %>

    <% if @session.present? %>
      <dl class="profile-list payment-complete-summary">
        <% if @session[:reference].present? %>
          <div class="profile-row profile-row--full">
            <dt>Referencia</dt>
            <dd><%= @session[:reference] %></dd>
          </div>
        <% end %>
        <% if @session[:amount].present? %>
          <div class="profile-row">
            <dt>Monto</dt>
            <dd><%= number_to_currency(@session[:amount], unit: "$", precision: 2) %></dd>
          </div>
        <% end %>
        <% if @session[:cuotas].present? %>
          <div class="profile-row">
            <dt>Cuotas</dt>
            <dd><%= Array(@session[:cuotas]).join(", ") %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>

    <p class="block-text payment-complete-countdown">Redirigiendo a tu panel en unos segundos…</p>

    <p class="panel-payment-actions">
      <%= link_to "Ir a mi panel ahora", @panel_url, class: "btn btn-primary", data: { turbo: false } %>
    </p>
  </section>

  <footer class="panel-footer">© CLEV · Sistema Administrativo de Estudiantes</footer>
</div>
