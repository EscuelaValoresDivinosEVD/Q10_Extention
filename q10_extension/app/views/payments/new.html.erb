<div class="payments-form">
  <h1>Pagar con Pagomedios</h1>
  <p class="subtitle">Ingresa el monto y genera un enlace seguro para cobrar con la pasarela Pagomedios.</p>

  <% if flash[:alert] %>
    <div class="flash alert" role="alert"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: pagar_path, method: :post, local: true, data: { turbo: false }, class: "payment-form" do |f| %>
    <div class="field">
      <label for="amount">Monto a pagar *</label>
      <input
        type="text"
        name="amount"
        id="amount"
        value="<%= params[:amount] %>"
        placeholder="Ej: 25.50"
        inputmode="decimal"
        pattern="[0-9]+([.,][0-9]+)?"
        required
        autofocus
      />
      <span class="hint">Usa punto o coma como separador decimal.</span>
    </div>

    <div class="field">
      <label for="currency">Moneda</label>
      <select name="currency" id="currency">
        <option value="USD" <%= "selected" if (params[:currency].presence || "USD") == "USD" %>>USD</option>
        <option value="EUR" <%= "selected" if params[:currency] == "EUR" %>>EUR</option>
      </select>
    </div>

    <div class="field optional">
      <label for="description">Descripción (opcional)</label>
      <input type="text" name="description" id="description" value="<%= params[:description] %>" placeholder="Ej: Pago de servicio" />
    </div>

    <div class="field optional">
      <label for="reference">Referencia (opcional)</label>
      <input type="text" name="reference" id="reference" value="<%= params[:reference] %>" placeholder="Ej: FACT-001" />
    </div>

    <div class="actions">
      <button type="submit" class="btn btn-primary">Generar enlace de pago</button>
    </div>
  <% end %>
</div>
