<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 640px; margin: 0 auto; font-family: Arial, Helvetica, sans-serif; color: #4f696e;">
  <% if @banner_cid.present? %>
    <tr>
      <td style="padding: 0 0 20px;">
        <img
          src="<%= @banner_cid %>"
          alt="Centro Latinoamericano de Estudios Védicos — Sabiduría milenaria para estos tiempos"
          width="640"
          style="display: block; width: 100%; max-width: 640px; height: auto; border: 0;"
        />
      </td>
    </tr>
  <% end %>

  <tr>
    <td style="padding: 0 0 12px; font-size: 16px; line-height: 1.5;">
      Hola,
    </td>
  </tr>

  <tr>
    <td style="padding: 0 0 12px; font-size: 15px; line-height: 1.55;">
      Recibimos tu solicitud para continuar con el proceso en el sistema CLEV.
    </td>
  </tr>

  <tr>
    <td style="padding: 0 0 16px; font-size: 15px; line-height: 1.55;">
      Haz clic en el botón para ver el detalle de tu deuda y continuar con el pago:
    </td>
  </tr>

  <tr>
    <td style="padding: 0 0 20px;">
      <a href="<%= @continue_url %>" style="display: inline-block; padding: 12px 20px; background: #4f696e; color: #ffffff; text-decoration: none; font-weight: bold; border-radius: 8px; font-size: 15px;">
        Continuar mi proceso
      </a>
    </td>
  </tr>

  <tr>
    <td style="padding: 0 0 12px; font-size: 13px; line-height: 1.5; word-break: break-all;">
      Si el botón no funciona, copia y pega este enlace en tu navegador:<br />
      <a href="<%= @continue_url %>" style="color: #4f696e;"><%= @continue_url %></a>
    </td>
  </tr>

  <tr>
    <td style="padding: 16px 0 0; font-size: 13px; line-height: 1.5; color: #6b7280;">
      Si no solicitaste este acceso, puedes ignorar este correo.
    </td>
  </tr>
</table>
