<% content_for :title, "Pagos registrados" %>

<div class="panel-page admin-payments-page">
  <header class="panel-banner">
    <div>
      <p class="panel-kicker">Administración</p>
      <h1 class="panel-title">Pagos registrados</h1>
      <p class="panel-doc"><%= pluralize(@payments.size, "registro", "registros") %> en total</p>
    </div>
  </header>

  <% if @status_counts.any? %>
    <section class="card block admin-payments-summary" aria-label="Resumen por estado">
      <% Payment::STATUSES.each do |status| %>
        <% count = @status_counts[status].to_i %>
        <div class="admin-payments-summary__item">
          <span class="<%= payment_status_class(status) %>"><%= payment_status_label(status) %></span>
          <strong><%= count %></strong>
        </div>
      <% end %>
      <div class="admin-payments-summary__item">
        <span class="status-pill status-pill--pending">Sin reportar en Q10</span>
        <strong><%= @q10_pending_report_count %></strong>
      </div>
    </section>
  <% end %>

  <% if @q10_pending_payments.any? %>
    <section class="card block" aria-label="Pagos aprobados pendientes de reporte en Q10">
      <div class="block-head">
        <h2 class="block-title">Conciliación Q10</h2>
        <p class="block-hint">Pagos autorizados en Pagomedios que aún no se reportaron en Q10.</p>
      </div>
      <div class="admin-payments-table-wrap">
        <table class="admin-payments-table">
          <thead>
            <tr>
              <th scope="col">Referencia</th>
              <th scope="col">Monto</th>
              <th scope="col">Identificación</th>
              <th scope="col">Estado Q10</th>
              <th scope="col">Motivo</th>
              <th scope="col">Autorizado</th>
              <th scope="col"><span class="visually-hidden">Detalle</span></th>
            </tr>
          </thead>
          <tbody>
            <% @q10_pending_payments.each do |payment| %>
              <tr>
                <td class="admin-payments-table__reference"><%= payment.reference %></td>
                <td><%= number_to_currency(payment.amount, unit: "$", precision: 2) %> <%= payment.currency %></td>
                <td><%= payment.numero_identificacion.presence || "—" %></td>
                <td class="admin-payments-table__q10-status">
                  <span class="<%= payment_q10_status_class(payment) %>">
                    <%= payment_q10_label(payment) %>
                  </span>
                </td>
                <td><%= payment.q10_error.presence || "Aún no se intentó reportar" %></td>
                <td><%= payment.transaction_at ? l(payment.transaction_at, format: :short) : l(payment.updated_at, format: :short) %></td>
                <td>
                  <%= link_to "Ver", admin_payment_path(payment), class: "btn btn-ghost admin-payments-table__link" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <section class="card block">
    <% if @payments.empty? %>
      <p class="block-text">Aún no hay pagos registrados en la base de datos.</p>
    <% else %>
      <div class="admin-payments-table-wrap">
        <table class="admin-payments-table">
          <thead>
            <tr>
              <th scope="col">ID</th>
              <th scope="col">Referencia</th>
              <th scope="col">Estado</th>
              <th scope="col">Monto</th>
              <th scope="col">Identificación</th>
              <th scope="col">Cuotas</th>
              <th scope="col">Crédito</th>
              <th scope="col">Q10</th>
              <th scope="col">Creado</th>
              <th scope="col"><span class="visually-hidden">Detalle</span></th>
            </tr>
          </thead>
          <tbody>
            <% @payments.each do |payment| %>
              <tr>
                <td><%= payment.id %></td>
                <td class="admin-payments-table__reference"><%= payment.reference %></td>
                <td>
                  <span class="<%= payment_status_class(payment.status) %>">
                    <%= payment_status_label(payment.status) %>
                  </span>
                </td>
                <td><%= number_to_currency(payment.amount, unit: "$", precision: 2) %> <%= payment.currency %></td>
                <td><%= payment.numero_identificacion.presence || "—" %></td>
                <td><%= payment_cuotas_label(payment.cuotas) %></td>
                <td><%= payment.consecutivo_credito.presence || "—" %></td>
                <td class="admin-payments-table__q10-status">
                  <span class="<%= payment_q10_status_class(payment) %>">
                    <%= payment_q10_label(payment) %>
                  </span>
                </td>
                <td><%= l(payment.created_at, format: :short) %></td>
                <td>
                  <%= link_to "Ver", admin_payment_path(payment), class: "btn btn-ghost admin-payments-table__link" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <footer class="panel-footer">© CLEV · Panel de pagos</footer>
</div>
