# Copia este archivo a .env y completa los valores.
# Rails carga .env automáticamente en desarrollo y test (gem dotenv).

# --- Base de datos (desarrollo local) ---
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- Aplicación ---
# APP_HOST=clev.evdsky.com          # Producción: host público para URLs de correo
# ALLOWED_HOSTS=clev.evdsky.com     # Producción: hosts permitidos (coma-separados)
# APP_MAILER_FROM=no-reply@evdsky.com

# --- Pagomedios (obligatorio en todos los ambientes) ---
PAGOMEDIOS_API_TOKEN=

# --- Q10 API ---
Q10_ENABLED=true
Q10_API_BASE_URL=https://api.q10.com/v1
Q10_CONSECUTIVO_PERIODO=12
Q10_SUBSCRIPTION_KEY=
Q10_API_KEY=
# Obligatorio para reportar pagos a Q10 tras cobro exitoso:
Q10_CODIGO_CAJERO=

# Solo desarrollo: omitir validación de créditos en el formulario de acceso
# (útil para probar UI sin conexión a Q10)
# Q10_SKIP_CREDITOS_CHECK=true

# --- Correo ---
# Desarrollo: si no se define, los correos se abren en /letter_opener
# Producción: obligatorio
# SPARKPOST_SMTP_API_KEY=
# SPARKPOST_SMTP_DOMAIN=evdsky.com

# --- Producción (Rails / deploy) ---
# RAILS_LOG_LEVEL=info
# Q10_EXTENSION_DATABASE_PASSWORD=
